# Listas iniciales
lista1 = [3, 1, 4]
lista2 = [2, 5, 6]

# Concatenar las dos listas utilizando el operador +
lista_concatenada = lista1 + lista2

# Ordenar el resultado utilizando sorted() para obtener una nueva lista ordenada
lista_ordenada = sorted(lista_concatenada)

# Mostrar el resultado
print(f"Lista 1: {lista1}")
print(f"Lista 2: {lista2}")
print(f"Lista concatenada y ordenada: {lista_ordenada}")
