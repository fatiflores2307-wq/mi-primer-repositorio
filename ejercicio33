# Altura de la pirámide
altura = 4

# Bucle para generar cada fila de la pirámide
for i in range(1, altura + 1):
    # 1. Crear los espacios a la izquierda para alinear la pirámide
    espacios = " " * (altura - i)
    
    # 2. Crear la parte ascendente de los números (desde 1 hasta i)
    ascendente = "".join(str(x) for x in range(1, i + 1))
    
    # 3. Crear la parte descendente de los números (desde i - 1 hasta 1)
    descendente = "".join(str(x) for x in range(i - 1, 0, -1))
    
    # 4. Concatenar y mostrar la línea completa
    print(espacios + ascendente + descendente)
