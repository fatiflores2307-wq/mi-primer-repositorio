# Función auxiliar para verificar si un número es primo
def es_primo(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    
    # Comprobar divisores impares hasta la raíz cuadrada
    limite = int(math.isqrt(n))
    for i in range(3, limite + 1, 2):
        if n % i == 0:
            return False
    return True

# Rango definido para la búsqueda de primos (del 1 al 50)
rango_inicio = 1
rango_fin = 50

# Generar la lista de números primos usando list comprehension
primos_en_rango = [num for num in range(rango_inicio, rango_fin + 1) if es_primo(num)]

# Mostrar el resultado
print(f"Rango evaluado: {rango_inicio} a {rango_fin}")
print("Números primos encontrados:")
print(primos_en_rango)
