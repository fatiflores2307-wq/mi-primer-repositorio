# Variables iniciales
num1 = 10
num2 = 5
operador = "+"

# Realizar la operación según el operador
if operador == "+":
    resultado = num1 + num2
elif operador == "-":
    resultado = num1 - num2
elif operador == "*":
    resultado = num1 * num2
elif operador == "/":
    if num2 != 0:
        resultado = num1 / num2
    else:
        resultado = "Error: División por cero"
else:
    resultado = "Operador no válido"

# Mostrar el resultado
print(f"Resultado: {num1} {operador} {num2} = {resultado}")
