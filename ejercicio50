import random

# 1. Generar un número aleatorio entre 1 y 100
numero_secreto = random.randint(1, 100)

print("=========================================")
print("  ¡BIENVENIDO A ADIVINA EL NÚMERO SECRETO!")
print("=========================================")
print("He elegido un número entre 1 y 100. ¡Intenta adivinarlo!\n")

intentos = 0
adivinado = False

# 2. Bucle principal del juego
while not adivinado:
    try:
        # Solicitar entrada al usuario
        suposicion = int(input("Ingresa tu número: "))
        intentos += 1
        
        # 3. Dar pistas ("muy alto" o "muy bajo") o indicar si adivinó
        if suposicion == numero_secreto:
            adivinado = True
            print(f"\n¡EXCELENTE! Has adivinado el número secreto ({numero_secreto}) en {intentos} intentos.")
        elif suposicion < numero_secreto:
            print("El número ingresado es muy bajo. ¡Inténtalo de nuevo!")
        else:
            print("El número ingresado es muy alto. ¡Inténtalo de nuevo!")
            
    except ValueError:
        print("Error: Ingresa un número entero válido.")
